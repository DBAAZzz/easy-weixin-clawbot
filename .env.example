# ── API Key ─────────────────────────────────────────────────────────────────
# 通用 key（LLM_API_KEY 优先，KEY 作为备选），适合 Kimi / Moonshot 等不在
# pi-ai 内置 env 映射里的 provider。
# 也可以用 provider 对应的标准变量名（见下方注释），此时可留空 LLM_API_KEY。
LLM_API_KEY=

# ── Provider & Model ─────────────────────────────────────────────────────────
# Kimi / Moonshot 标准聊天 API（https://api.moonshot.cn/v1）
#   LLM_PROVIDER=moonshot
#   LLM_MODEL=moonshot-v1-8k   # 可选: moonshot-v1-32k | moonshot-v1-128k
#
# Kimi K2 编程 API（pi-ai 内置，从 KIMI_API_KEY 读 key）
#   LLM_PROVIDER=kimi-coding
#   LLM_MODEL=kimi-k2-thinking  # 可选: kimi-k2.5
#
# Anthropic（从 ANTHROPIC_API_KEY 读 key）
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-sonnet-4-20250514
#
# OpenAI（从 OPENAI_API_KEY 读 key）
#   LLM_PROVIDER=openai
#   LLM_MODEL=gpt-4o

LLM_PROVIDER=moonshot
LLM_MODEL=moonshot-v1-8k

# ── System Prompt ─────────────────────────────────────────────────────────────
SYSTEM_PROMPT=你是一个微信智能助手，回答简洁、友好。

# ── Web Console & Persistence ────────────────────────────────────────────────
SUPABASE_PASSWORD=
DATABASE_URL=
DIRECT_URL=
API_PORT=3001
API_SECRET=
WEB_ORIGIN=http://localhost:5173

# ── TTS (Text-to-Speech) ───────────────────────────────────────────────────
# Provider: edge-tts (default). Add custom providers via registerTTSProvider().
TTS_PROVIDER=edge-tts
# Default voice for Edge TTS. Run `edge-tts voice-list` to see all options.
TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
