{
  "js/ts.tsdk.path": "packages/agent/node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Always generate commit messages in English. Use the Conventional Commits specification.  "
    }
  ],
  "cssVariables.lookupFiles": [
    "packages/ui/src/**/*.css"
  ],
  "cssVariables.blacklistFolders": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/docs-dist",
    "**/CVS",
    "**/.DS_Store",
    "**/.next",
    "**/.cache",
    "**/node_modules",
    "**/bower_components",
    "**/dist",
    "**/build",
    "**/out",
    "**/tmp"
  ]
}
