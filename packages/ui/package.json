{
  "name": "@clawbot/ui",
  "version": "1.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./style.css": "./dist/style.css",
    "./sonner.css": "./dist/sonner.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "scripts": {
    "build": "tsdown && node scripts/bundle-css.mjs && cp src/sonner.css dist/sonner.css",
    "dev": "tsdown --watch",
    "docs:dev": "dumi dev",
    "docs:build": "dumi build",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt 'src/**/*.{ts,tsx,md,css}' '.dumi/**/*.{ts,tsx,css}' docs scripts package.json tsconfig.json .dumirc.ts tsdown.config.ts",
    "fmt:check": "oxfmt --check 'src/**/*.{ts,tsx,md,css}' '.dumi/**/*.{ts,tsx,css}' docs scripts package.json tsconfig.json .dumirc.ts tsdown.config.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "clsx": "^2.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tsdown/css": "0.22.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dumi": "^2.4.30",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.22.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
