# ============================================================================
# ClawBot Docker Compose Environment Variables
# Copy this file to .env and fill in the required values.
# ============================================================================

# ── Docker Registry Mirror (for China users) ───────────────────────────────
# Uncomment ONE of the lines below if Docker Hub is inaccessible:
# REGISTRY=docker.m.daocloud.io/library/
# REGISTRY=registry.cn-hangzhou.aliyuncs.com/library/

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=clawbot
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=clawbot
# POSTGRES_PORT=5432          # Host port for direct DB access (optional)

# ── Credential Encryption (REQUIRED for production) ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLAWBOT_CREDENTIAL_KEY=

# ── LLM Configuration ──────────────────────────────────────────────────────
LLM_API_KEY=
LLM_PROVIDER=moonshot
LLM_MODEL=moonshot-v1-8k

# Provider-specific API keys (set the one matching your LLM_PROVIDER)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# KIMI_API_KEY=

# ── System Prompt ───────────────────────────────────────────────────────────
SYSTEM_PROMPT=你是一个微信智能助手，回答简洁、友好。

# ── TTS (Text-to-Speech) ───────────────────────────────────────────────────
TTS_PROVIDER=edge-tts
TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural

# ── Ports ───────────────────────────────────────────────────────────────────
# API_PORT=8028              # Host port for direct API access (optional)
# WEB_PORT=80                # Host port for Web UI (via Nginx)
