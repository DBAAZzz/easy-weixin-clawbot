{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@clawbot/ui": ["./src/index.ts"]
    },
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src", ".dumirc.ts", ".dumi/theme"]
}
