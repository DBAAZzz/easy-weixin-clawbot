# ============================================================================
# ClawBot 环境变量示例
# 1. 把本文件复制为仓库根目录的 `.env`
# 2. 所有配置只认这一份 `.env`
# 3. `packages/server` 和 `packages/web` 都会读取它
#
# 数据库二选一：
# 1. 用 Docker Compose 自带的 PostgreSQL：填写 `POSTGRES_*`
# 2. 用你自己的 PostgreSQL / Supabase：填写 `DATABASE_URL` / `DIRECT_URL`
# ============================================================================

# ── Docker Compose 自带 PostgreSQL ─────────────────────────────────────────
# 大多数用户直接用这一组即可。
POSTGRES_USER=clawbot
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=clawbot
# POSTGRES_PORT=5432   # 可选：把数据库端口暴露到宿主机时使用

# ── 凭据加密主密钥 ─────────────────────────────────────────────────────────
# 用于加密微信登录凭据等敏感数据。请使用 32 字节随机十六进制字符串。
CLAWBOT_CREDENTIAL_KEY=

# ── LLM Provider 配置说明 ─────────────────────────────────────────────────
# 运行时不再从环境变量读取 LLM Provider、模型或 API Key。
# 启动后请登录 Web 管理后台，在“模型配置”页面：
# 1. 创建 Provider 模板
# 2. 填写 API Key / Base URL / 模型列表
# 3. 创建全局、账号或会话级使用配置
#
# 保留在本地 `.env` 里的 `LLM_*`、`OPENAI_API_KEY`、`ANTHROPIC_API_KEY`、
# `KIMI_API_KEY` 等变量不会生效。

# ── 外部数据库 / Supabase ───────────────────────────────────────────────────
# 如果你不用 Docker Compose 自带数据库，就必须填写这两项。
# 推荐直接从数据库服务控制台复制完整连接串，不要手动拼接。
# 对 Supabase 来说，通常：
# - DATABASE_URL 填 pooler / session 模式连接串，并带上 `?sslmode=require`
# - DIRECT_URL 优先填 direct connection；如果当前网络/代理环境连不通 direct host，可先改用可访问的 session pooler 连接串，并带上 `?sslmode=require`
DATABASE_URL=
DIRECT_URL=

# ── Web 后台与服务运行参数 ─────────────────────────────────────────────────
# API_PORT：后端服务端口
# WEB_ORIGIN：允许访问后端的 Web 地址，开发环境默认是 Vite 的 5173
API_PORT=8028
WEB_ORIGIN=http://localhost:5173

# ── 后台登录账号（JWT 登录）─────────────────────────────────────────────────
# 这是你登录 Web 管理后台时使用的用户名和密码。
# AUTH_JWT_SECRET 一定要改成你自己的随机字符串，生产环境不要用默认值。
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
AUTH_JWT_SECRET=change-me-to-a-random-secret-key
AUTH_TOKEN_EXPIRY=24h   # 例如：12h / 24h / 7d

# ── 语音合成（TTS）──────────────────────────────────────────────────────────
# 默认使用 edge-tts，通常不需要改。
TTS_PROVIDER=edge-tts
# 默认语音。可执行 `edge-tts voice-list` 查看更多可选语音。
TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
