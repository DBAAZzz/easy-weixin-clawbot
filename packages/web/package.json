{
  "name": "@clawbot/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:arbitrary": "! grep -rnE '(bg|text|border|rounded|shadow|ring|ease|tracking)-\\[' src/ --include='*.tsx' --include='*.ts' | grep -vF -f .token-exempt-whitelist | grep -v 'linear-gradient' | grep -v 'inset_0' | grep -v 'calc('"
  },
  "dependencies": {
    "@clawbot/shared": "workspace:*",
    "@tanstack/react-query": "^5.97.0",
    "clsx": "^2.1.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.2"
  }
}
