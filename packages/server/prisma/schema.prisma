generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id           String         @id @db.Text
  displayName  String?        @map("display_name") @db.Text
  alias        String?        @db.Text
  deprecated   Boolean        @default(false)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  conversations  Conversation[]
  messages       Message[]
  sessionRoutes  SessionRoute[]
  webhookPermissions WebhookAccountPermission[]
  tapeEntries    TapeEntry[]
  tapeAnchors    TapeAnchor[]

  @@map("accounts")
}

model Conversation {
  id             BigInt    @id @default(autoincrement())
  accountId      String    @map("account_id") @db.Text
  conversationId String    @map("conversation_id") @db.Text
  title          String?   @db.Text
  lastMessageAt  DateTime? @map("last_message_at") @db.Timestamptz(6)
  messageCount   Int       @default(0) @map("message_count")
  contextToken   String?   @map("context_token") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  account        Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, conversationId], map: "conversations_account_id_conversation_id_key")
  @@index([accountId], map: "idx_conversations_account")
  @@map("conversations")
}

model SessionRoute {
  id              BigInt   @id @default(autoincrement())
  accountId       String   @map("account_id") @db.Text
  wechatConvId    String   @map("wechat_conv_id") @db.Text
  effectiveConvId String   @map("effective_conv_id") @db.Text
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, wechatConvId], map: "session_routes_account_id_wechat_conv_id_key")
  @@map("session_routes")
}

model McpServer {
  id         BigInt   @id @default(autoincrement())
  name       String   @db.Text
  slug       String   @unique @db.Text
  transport  String   @db.Text
  command    String   @db.Text
  argsJson   Json     @map("args_json")
  envJson    Json     @map("env_json")
  cwd        String?  @db.Text
  enabled    Boolean  @default(true)
  status     String   @default("disconnected") @db.Text
  lastError  String?  @map("last_error") @db.Text
  lastSeenAt DateTime? @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tools      McpTool[]

  @@index([enabled], map: "idx_mcp_servers_enabled")
  @@map("mcp_servers")
}

model McpTool {
  id         BigInt   @id @default(autoincrement())
  serverId   BigInt   @map("server_id")
  remoteName String   @map("remote_name") @db.Text
  localName  String   @map("local_name") @db.Text
  summary    String?  @db.Text
  inputSchema Json    @map("input_schema")
  enabled    Boolean  @default(true)
  lastSeenAt DateTime? @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  server     McpServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, remoteName], map: "mcp_tools_server_id_remote_name_key")
  @@unique([localName], map: "mcp_tools_local_name_key")
  @@index([serverId], map: "idx_mcp_tools_server")
  @@index([enabled], map: "idx_mcp_tools_enabled")
  @@map("mcp_tools")
}

model Message {
  id             BigInt   @id @default(autoincrement())
  accountId      String   @map("account_id") @db.Text
  conversationId String   @map("conversation_id") @db.Text
  seq            Int
  role           String   @db.Text
  contentText    String?  @map("content_text") @db.Text
  payload        Json
  mediaType      String?  @map("media_type") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, conversationId, seq], map: "messages_account_id_conversation_id_seq_key")
  @@index([accountId, conversationId, id], map: "idx_messages_lookup")
  @@map("messages")
}

model WebhookToken {
  id          BigInt                      @id @default(autoincrement())
  source      String                      @unique @db.Text
  tokenHash   String                      @map("token_hash") @db.Text
  tokenPrefix String                      @map("token_prefix") @db.Text
  description String?                     @db.Text
  enabled     Boolean                     @default(true)
  createdAt   DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastUsedAt  DateTime?                   @map("last_used_at") @db.Timestamptz(6)
  permissions WebhookAccountPermission[]
  logs        WebhookLog[]

  @@index([tokenHash], map: "idx_webhook_tokens_hash")
  @@map("webhook_tokens")
}

model WebhookAccountPermission {
  tokenId   BigInt       @map("token_id")
  accountId String       @map("account_id") @db.Text
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  token     WebhookToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  account   Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([tokenId, accountId])
  @@index([accountId], map: "idx_webhook_permissions_account")
  @@map("webhook_account_permissions")
}

model WebhookLog {
  id             BigInt       @id @default(autoincrement())
  tokenId        BigInt       @map("token_id")
  accountId      String       @map("account_id") @db.Text
  conversationId String       @map("conversation_id") @db.Text
  content        String       @db.Text
  status         String       @db.Text
  error          String?      @db.Text
  idempotencyKey String?      @map("idempotency_key") @db.Text
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  token          WebhookToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId, createdAt(sort: Desc)], map: "idx_webhook_logs_token")
  @@index([accountId, createdAt(sort: Desc)], map: "idx_webhook_logs_account")
  @@index([idempotencyKey], map: "idx_webhook_logs_idempotency")
  @@map("webhook_logs")
}

model Trace {
  id             BigInt      @id @default(autoincrement())
  traceId        String      @unique @map("trace_id") @db.Text
  accountId      String      @map("account_id") @db.Text
  conversationId String      @map("conversation_id") @db.Text
  totalMs        Int         @map("total_ms")
  llmRounds      Int         @map("llm_rounds")
  toolCalls      Int         @map("tool_calls")
  inputTokens    Int         @map("input_tokens")
  outputTokens   Int         @map("output_tokens")
  stopReason     String      @map("stop_reason") @db.Text
  error          String?     @db.Text
  flags          String      @default("") @db.Text
  sampled        Boolean     @default(true)
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  spans          TraceSpan[]

  @@index([accountId, createdAt(sort: Desc)], map: "idx_traces_account_created")
  @@index([conversationId, createdAt(sort: Desc)], map: "idx_traces_conversation_created")
  @@index([flags, createdAt(sort: Desc)], map: "idx_traces_flags_created")
  @@index([sampled, createdAt(sort: Desc)], map: "idx_traces_sampled_created")
  @@map("traces")
}

model TraceSpan {
  id           BigInt    @id @default(autoincrement())
  traceId      String    @map("trace_id") @db.Text
  spanId       String    @map("span_id") @db.Text
  parentSpanId String?   @map("parent_span_id") @db.Text
  name         String    @db.Text
  startTime    DateTime  @map("start_time") @db.Timestamptz(6)
  durationMs   Int       @map("duration_ms")
  status       String    @db.Text
  toolName     String?   @map("tool_name") @db.Text
  model        String?   @db.Text
  inputTokens  Int?      @map("input_tokens")
  outputTokens Int?      @map("output_tokens")
  stopReason   String?   @map("stop_reason") @db.Text
  errorMessage String?   @map("error_message") @db.Text
  payload      String?   @db.Text
  trace        Trace     @relation(fields: [traceId], references: [traceId], onDelete: Cascade)

  @@unique([traceId, spanId], map: "trace_spans_trace_id_span_id_key")
  @@index([traceId], map: "idx_trace_spans_trace")
  @@index([name, startTime(sort: Desc)], map: "idx_trace_spans_name_start")
  @@index([toolName, status], map: "idx_trace_spans_tool_status")
  @@index([status, startTime(sort: Desc)], map: "idx_trace_spans_status_start")
  @@map("trace_spans")
}

// ─── Scheduler ────────────────────────────────────────────────────────

model ScheduledTask {
  id             BigInt    @id @default(autoincrement())
  taskId         String    @unique @default(dbgenerated("gen_random_uuid()")) @map("task_id") @db.Uuid
  accountId      String    @map("account_id") @db.Text
  conversationId String    @map("conversation_id") @db.Text
  seq            Int                                         // per-account auto-increment short ID
  name           String    @db.Text
  prompt         String    @db.Text
  cron           String    @db.Text
  timezone       String    @default("Asia/Shanghai") @db.Text
  enabled        Boolean   @default(true)
  status         String    @default("idle") @db.Text         // idle | running | error | paused
  lastRunAt      DateTime? @map("last_run_at") @db.Timestamptz(6)
  nextRunAt      DateTime? @map("next_run_at") @db.Timestamptz(6)
  lastError      String?   @map("last_error") @db.Text
  runCount       Int       @default(0) @map("run_count")
  failStreak     Int       @default(0) @map("fail_streak")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  runs           ScheduledTaskRun[]

  @@unique([accountId, seq], map: "scheduled_tasks_account_id_seq_key")
  @@index([accountId, enabled], map: "idx_scheduled_tasks_account_enabled")
  @@map("scheduled_tasks")
}

model ScheduledTaskRun {
  id         BigInt   @id @default(autoincrement())
  taskId     BigInt   @map("task_id")
  status     String   @db.Text                               // success | error | timeout | skipped
  prompt     String   @db.Text
  result     String?  @db.Text
  durationMs Int?     @map("duration_ms")
  error      String?  @db.Text
  pushed     Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  task       ScheduledTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt(sort: Desc)], map: "idx_scheduled_task_runs_task")
  @@map("scheduled_task_runs")
}

// ─── Tape Memory System ───────────────────────────────────────────────

model TapeEntry {
  id         BigInt   @id @default(autoincrement())
  eid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId  String   @map("account_id") @db.Text
  branch     String   @db.Text

  // tape.systems Entry fields
  type       String   @db.Text                           // 'record' | 'anchor'
  category   String   @db.Text                           // 'fact' | 'preference' | 'decision' | 'summary'

  // Fact payload: structured as Fragment array
  payload    Json

  // Meta
  actor      String   @db.Text                           // 'user:{accountId}' | 'agent:{modelId}' | 'system'
  source     String?  @db.Text                           // 'chat' | 'tool:{toolName}' | 'compact'

  // Optional hash chain for integrity (single-trust system, nullable)
  prevHash   String?  @map("prev_hash") @db.Text

  compacted  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, branch, type], map: "idx_tape_branch_type")
  @@index([accountId, branch, createdAt], map: "idx_tape_branch_created")
  @@index([accountId, branch, compacted], map: "idx_tape_branch_compacted")
  @@map("tape_entries")
}

/// Anchor: state checkpoint separated from Entry for distinct query patterns and schema
model TapeAnchor {
  id             BigInt   @id @default(autoincrement())
  aid            String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId      String   @map("account_id") @db.Text
  branch         String   @db.Text

  // checkpoint | handoff | decision
  anchorType     String   @map("anchor_type") @db.Text

  // Folded state snapshot
  snapshot       Json

  // Entry eids that produced this snapshot (traceability)
  manifest       String[] @default([])

  // Predecessor anchor aids (DAG for branching/merging)
  predecessors   String[] @default([])

  // Last Entry eid covered by this anchor (recall incremental start point)
  lastEntryEid   String?  @map("last_entry_eid") @db.Uuid

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, branch, anchorType], map: "idx_anchor_branch_type")
  @@index([accountId, branch, createdAt], map: "idx_anchor_branch_created")
  @@map("tape_anchors")
}
