# ============================================================================
# ClawBot 环境变量示例
# 1. 把本文件复制为仓库根目录的 `.env`
# 2. 所有配置只认这一份 `.env`
# 3. `packages/server` 和 `packages/web` 都会读取它
#
# 数据库二选一：
# 1. 用 Docker Compose 自带的 PostgreSQL：填写 `POSTGRES_*`
# 2. 用你自己的 PostgreSQL / Supabase：填写 `DATABASE_URL` / `DIRECT_URL`
# ============================================================================

# ── Docker Compose 自带 PostgreSQL ─────────────────────────────────────────
# 大多数用户直接用这一组即可。
POSTGRES_USER=clawbot
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=clawbot
# POSTGRES_PORT=5432   # 可选：把数据库端口暴露到宿主机时使用

# ── LLM API Key ─────────────────────────────────────────────────────────────
# 通用模型密钥。
# 如果你只想快速跑起来，通常填 `LLM_API_KEY` 就够了。
# 某些 provider 也支持专用变量名，例如 `OPENAI_API_KEY`、`ANTHROPIC_API_KEY`、
# `KIMI_API_KEY`，那种情况下可以不填 `LLM_API_KEY`。
LLM_API_KEY=

# ── 模型提供商与模型名 ──────────────────────────────────────────────────────
# 没有特别偏好，建议先用默认的 Moonshot / Kimi。
#
# Moonshot 标准聊天接口（https://api.moonshot.cn/v1）
#   LLM_PROVIDER=moonshot
#   LLM_MODEL=moonshot-v1-8k   # 可改成：moonshot-v1-32k / moonshot-v1-128k
#
# Kimi K2 编程模型（从 KIMI_API_KEY 读取密钥）
#   LLM_PROVIDER=kimi-coding
#   LLM_MODEL=kimi-k2-thinking  # 可改成：kimi-k2.5
#
# Anthropic（从 ANTHROPIC_API_KEY 读取密钥）
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-sonnet-4-20250514
#
# OpenAI（从 OPENAI_API_KEY 读取密钥）
#   LLM_PROVIDER=openai
#   LLM_MODEL=gpt-4o

LLM_PROVIDER=moonshot
LLM_MODEL=moonshot-v1-8k

# ── 外部数据库 / Supabase ───────────────────────────────────────────────────
# 如果你不用 Docker Compose 自带数据库，就必须填写这两项。
# 推荐直接从数据库服务控制台复制完整连接串，不要手动拼接。
# 对 Supabase 来说，通常：
# - DATABASE_URL 填 pooler / session 模式连接串
# - DIRECT_URL 填 direct connection 连接串
DATABASE_URL=
DIRECT_URL=

# ── Web 后台与服务运行参数 ─────────────────────────────────────────────────
# API_PORT：后端服务端口
# WEB_ORIGIN：允许访问后端的 Web 地址，开发环境默认是 Vite 的 5173
API_PORT=8028
WEB_ORIGIN=http://localhost:5173

# ── 后台登录账号（JWT 登录）─────────────────────────────────────────────────
# 这是你登录 Web 管理后台时使用的用户名和密码。
# AUTH_JWT_SECRET 一定要改成你自己的随机字符串，生产环境不要用默认值。
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
AUTH_JWT_SECRET=change-me-to-a-random-secret-key
AUTH_TOKEN_EXPIRY=24h   # 例如：12h / 24h / 7d

# ── 语音合成（TTS）──────────────────────────────────────────────────────────
# 默认使用 edge-tts，通常不需要改。
TTS_PROVIDER=edge-tts
# 默认语音。可执行 `edge-tts voice-list` 查看更多可选语音。
TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
